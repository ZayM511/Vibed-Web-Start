{
  "manifest_version": 3,
  "name": "JobFiltr - Job Search Power Tool",
  "version": "2.0.0",
  "description": "Your job search, upgraded. Ghost job & scam detection, smart filters, job age badges, and more for LinkedIn and Indeed.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs",
    "scripting",
    "contextMenus",
    "notifications",
    "system.display"
  ],
  "options_page": "settings.html",
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*"
  ],
  "action": {
    "default_popup": "popup-v2.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["src/storage-utils.js", "src/linkedin-feature-flags.js", "src/linkedin-job-cache.js", "src/linkedin-badge-manager.js", "src/content-linkedin-v3.js", "src/ghost-detection-bundle.js"],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.indeed.com/*"],
      "js": ["src/storage-utils.js", "src/content-indeed-v3.js", "src/ghost-detection-bundle.js"],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "styles/*", "fonts/*"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["src/linkedin-api-interceptor.js"],
      "matches": ["https://*.linkedin.com/*"]
    },
    {
      "resources": ["src/indeed-mosaic-extractor.js"],
      "matches": ["https://*.indeed.com/*"]
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://www.jobfiltr.app/*",
      "https://jobfiltr.app/*",
      "http://localhost:3000/*"
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
